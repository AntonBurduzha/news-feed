{
	"name": "@news-feed/auth-service",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"main": "./dist/src/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node dist/src/index.js",
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.ts\" \"*.ts\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"http-status": "^2.1.0",
		"jose": "^6.2.3",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"redis": "^5.12.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.0",
		"pino-pretty": "^13.1.3",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
