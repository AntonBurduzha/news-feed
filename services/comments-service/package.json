{
	"name": "@news-feed/comments-service",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"main": "./dist/src/index.js",
	"scripts": {
		"dev": "tsx --import ./src/lib/tracing.ts --watch src/index.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node --import ./dist/src/lib/tracing.js dist/src/index.js",
		"test:unit": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.ts\" \"*.ts\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@news-feed/auth-client": "*",
		"@news-feed/contracts": "*",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.76.0",
		"@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
		"@opentelemetry/instrumentation-kafkajs": "^0.27.0",
		"@opentelemetry/instrumentation-mongodb": "^0.71.0",
		"@opentelemetry/sdk-node": "^0.218.0",
		"@opentelemetry/sdk-trace-base": "^2.7.1",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"http-status": "^2.1.0",
		"kafkajs": "^2.2.4",
		"mongoose": "^9.4.1",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"prom-client": "^15.1.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@vitest/coverage-v8": "^4.1.9",
		"dotenv": "^17.4.0",
		"pino-pretty": "^13.1.3",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
