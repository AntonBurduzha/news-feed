{
	"name": "@news-feed/monolith",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"main": "./dist/src/index.js",
	"scripts": {
		"dev": "tsx --import ./src/lib/tracing.ts --watch src/index.ts",
		"worker:fan-out": "OTEL_SERVICE_NAME=fan-out tsx --import ./src/lib/tracing.ts --watch workers/fan-out.ts",
		"worker:outbox": "OTEL_SERVICE_NAME=outbox-relay tsx --import ./src/lib/tracing.ts --watch workers/outbox-relay.ts",
		"worker:outbox-cleaner": "OTEL_SERVICE_NAME=outbox-cleaner tsx --import ./src/lib/tracing.ts --watch workers/outbox-cleaner.ts",
		"worker:dlq-redrive": "OTEL_SERVICE_NAME=dlq-redrive tsx --import ./src/lib/tracing.ts --watch workers/dlq-redrive.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node --import ./dist/src/lib/tracing.js dist/src/index.js",
		"migrate:postgres": "node-pg-migrate up -m ./src/db/postgres/migrations --tsx --tsconfig tsconfig.json",
		"migrate:postgres:down": "node-pg-migrate down -m ./src/db/postgres/migrations --tsx --tsconfig tsconfig.json",
		"migrate:postgres:create": "node-pg-migrate create -m ./src/db/postgres/migrations --migration-file-language ts",
		"test:unit": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"workers/**/*.ts\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1065.0",
		"@news-feed/auth-client": "*",
		"@news-feed/contracts": "*",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.76.0",
		"@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
		"@opentelemetry/instrumentation-kafkajs": "^0.27.0",
		"@opentelemetry/sdk-node": "^0.218.0",
		"@opentelemetry/sdk-trace-base": "^2.7.1",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"http-status": "^2.1.0",
		"kafkajs": "^2.2.4",
		"multer": "^2.1.1",
		"node-cron": "^4.2.1",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"prom-client": "^15.1.3",
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.5.0",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "^4.1.9",
		"dotenv": "^17.4.0",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"node-pg-migrate": "^8.0.4",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.9"
	}
}
