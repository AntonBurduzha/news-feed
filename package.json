{
	"name": "news-feed",
	"type": "module",
	"private": true,
	"workspaces": [
		"services/monolith",
		"services/comments-service",
		"services/shared/*"
	],
	"scripts": {
		"dev:monolith": "npm --workspace services/monolith run dev",
		"dev:comments": "npm --workspace services/comments-service run dev",
		"build": "npm run build --workspaces",
		"typecheck": "npm run typecheck --workspaces",
		"lint": "npm run lint --workspaces",
		"format": "prettier --write \"services/**/*.ts\" \"*.ts\" \"eslint.config.js\"",
		"start:monolith": "npm --workspace services/monolith run start",
		"start:comments": "npm --workspace services/comments-service run start",
		"migrate:postgres": "npm --workspace services/monolith run migrate:postgres",
		"migrate:postgres:down": "npm --workspace services/monolith run migrate:postgres:down",
		"migrate:postgres:create": "npm --workspace services/monolith run migrate:postgres:create",
		"worker:fan-out": "npm --workspace services/monolith run worker:fan-out",
		"worker:outbox": "npm --workspace services/monolith run worker:outbox",
		"worker:outbox-cleaner": "npm --workspace services/monolith run worker:outbox-cleaner"
	}
}
