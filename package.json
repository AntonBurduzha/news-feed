{
	"name": "news-feed",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"main": "./dist/src/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"worker:posts-create": "tsx watch workers/posts-create.ts",
		"worker:outbox": "tsx watch workers/outbox-relay.ts",
		"worker:outbox-cleaner": "tsx watch workers/outbox-cleaner.ts",
		"worker:comments-delete": "tsx watch workers/comments-delete.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node dist/src/index.js",
		"migrate:postgres": "node-pg-migrate up -m ./src/db/postgres/migrations --tsx --tsconfig tsconfig.json",
		"migrate:postgres:down": "node-pg-migrate down -m ./src/db/postgres/migrations --tsx --tsconfig tsconfig.json",
		"migrate:postgres:create": "node-pg-migrate create -m ./src/db/postgres/migrations --migration-file-language ts",
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"eslint.config.js\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"http-status": "^2.1.0",
		"kafkajs": "^2.2.4",
		"mongoose": "^9.4.1",
		"node-cron": "^4.2.1",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.0",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"node-pg-migrate": "^8.0.4",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0"
	}
}
